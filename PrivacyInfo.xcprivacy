<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Rheum Pie does not track users across other companies' apps or websites -->
    <key>NSPrivacyTracking</key>
    <false/>

    <!-- No tracking domains -->
    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!-- Required-reason APIs accessed by the app -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <dict>
            <!-- NSUserDefaults — stores bookmarks and category filter preference -->
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- CA92.1: Accessing info from same app that wrote it -->
                <string>CA92.1</string>
            </array>
        </dict>
    </array>

    <!--
        Collected data types.

        Notes:
        - Rheum Pie is a read-only, offline-first article reader.
        - All content is bundled in the app binary (seed JSON).
        - No user accounts, no analytics, no crash reporters, no third-party SDKs.
        - Bookmark state is stored locally in UserDefaults only.
        - Nothing is transmitted to any server.
    -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array/>
</dict>
</plist>
